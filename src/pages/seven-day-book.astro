---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sevenDayBookLanding as page } from "../data/seven-day-book";

const nav = [
  { href: "#impact", label: "成果" },
  { href: "#workflow", label: "流程" },
  { href: "#themes", label: "主題" },
  { href: "#partners", label: "合作" },
  { href: "#contact", label: "洽談" },
];
---

<BaseLayout
  title="Matters 七日書"
  description={page.description}
  bareChrome
  noMesh
  hideFooter
>
  <main class="sdb-page">
    <header class="sdb-header" aria-label="七日書頁首">
      <a
        class="sdb-brand"
        href="https://matters.town/@freewrite"
        target="_blank"
        rel="noopener"
      >
        Matters 七日書
      </a>
      <nav class="sdb-nav" aria-label="頁面導覽">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>

    <section class="sdb-hero" aria-labelledby="hero-title">
      <div class="sdb-hero__copy">
        <p class="sdb-kicker">For cultural partners and sponsors</p>
        <h1 id="hero-title">{page.title}</h1>
        <p class="sdb-hero__lead">{page.description}</p>
        <div class="sdb-actions" aria-label="主要行動">
          <a class="sdb-button sdb-button--primary" href="#contact">洽談合作</a>
          <a
            class="sdb-button sdb-button--secondary"
            href="https://matters.town/tags/167821-%E4%B8%83%E6%97%A5%E6%9B%B8"
            target="_blank"
            rel="noopener"
          >
            閱讀七日書作品
          </a>
        </div>
      </div>
      <aside class="sdb-hero__panel" aria-label="核心成果摘要">
        <img
          src="https://imagedelivery.net/kDRCweMmqLnTPNlbum-pYA/prod/cover/1060a3d5-cbb9-4140-9b04-a0acb011449a.jpeg/public"
          alt="七日書總結回顧封面"
          loading="eager"
        />
        <div class="sdb-hero__proof">
          <span>公開資料擷取</span>
          <strong>93 篇文章 · 185 張圖片 · 3009 參與人次</strong>
          <small>參與人次為已擷取完結報告各期加總</small>
        </div>
      </aside>
    </section>

    <section
      id="impact"
      class="sdb-section sdb-section--tight"
      aria-labelledby="impact-title"
    >
      <div class="sdb-section__head">
        <p class="sdb-kicker">Measured impact</p>
        <h2 id="impact-title">讓合作方一眼看懂的成果數據</h2>
        <p>{page.sourceNote}</p>
      </div>
      <div class="sdb-metric-grid">
        {
          page.metrics.map((metric) => (
            <article class="sdb-metric">
              <strong>
                {metric.value}
                <span>{metric.unit}</span>
              </strong>
              <p>{metric.label}</p>
              <small>{metric.source}</small>
            </article>
          ))
        }
      </div>
      <div class="sdb-source-row">
        <a href={page.primarySource.href} target="_blank" rel="noopener">
          來源：{page.primarySource.label}
        </a>
        <span>{page.primarySource.date}</span>
      </div>
    </section>

    <section
      class="sdb-section sdb-section--split"
      aria-labelledby="account-title"
    >
      <div class="sdb-section__head">
        <p class="sdb-kicker">Scraped official account</p>
        <h2 id="account-title">已整理成可延伸分析的官方帳號資料</h2>
      </div>
      <div class="sdb-account">
        {
          page.accountMetrics.map((item) => (
            <article>
              <strong>{item.value}</strong>
              <span>{item.label}</span>
              <small>{item.source}</small>
            </article>
          ))
        }
      </div>
      <div class="sdb-note">
        {page.caveats.map((item) => <p>{item}</p>)}
      </div>
    </section>

    <section id="workflow" class="sdb-section" aria-labelledby="workflow-title">
      <div class="sdb-section__head">
        <p class="sdb-kicker">How it works</p>
        <h2 id="workflow-title">從題目、書寫到公共可見度的三步流程</h2>
      </div>
      <div class="sdb-workflow">
        {
          page.workflow.map((step) => (
            <article>
              <span>{step.step}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </article>
          ))
        }
      </div>
      <p class="sdb-section__after">
        每月常態節奏可結合作家講座、完結報告、大滿貫徽章與鏈上參與憑證，形成從參與到紀念的完整活動路徑。
      </p>
    </section>

    <section id="themes" class="sdb-section" aria-labelledby="themes-title">
      <div class="sdb-section__head">
        <p class="sdb-kicker">Life issue map</p>
        <h2 id="themes-title">人生議題地圖</h2>
        <p>
          每張主題卡都導向至少一篇官方文章，讓合作方可快速理解題目如何打開作者群與作品脈絡。
        </p>
      </div>
      <div class="sdb-theme-grid">
        {
          page.themes.map((theme) => (
            <article class="sdb-theme">
              <div class="sdb-theme__images">
                {theme.articles.map((article) => (
                  <a
                    href={article.href}
                    target="_blank"
                    rel="noopener"
                    aria-label={article.title}
                  >
                    <img
                      src={article.image}
                      alt={`${article.title} 封面`}
                      loading="lazy"
                    />
                  </a>
                ))}
              </div>
              <div>
                <h3>{theme.group}</h3>
                <p>{theme.summary}</p>
                <div class="sdb-inline-links">
                  {theme.articles.map((article) => (
                    <a href={article.href} target="_blank" rel="noopener">
                      {article.title}
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section
      class="sdb-section sdb-section--split"
      aria-labelledby="meaning-title"
    >
      <div class="sdb-section__head">
        <p class="sdb-kicker">Public meaning</p>
        <h2 id="meaning-title">把私人日記轉化為集體生命檔案</h2>
      </div>
      <div class="sdb-values">
        {
          page.publicValues.map((value) => (
            <article>
              <h3>{value.title}</h3>
              <p>{value.body}</p>
            </article>
          ))
        }
      </div>
      <div class="sdb-keywords" aria-label="九個核心詞彙">
        {page.keywords.map((keyword) => <span>{keyword}</span>)}
      </div>
    </section>

    <section
      id="partners"
      class="sdb-section sdb-case"
      aria-labelledby="case-title"
    >
      <div class="sdb-case__media">
        <img
          src={page.caseStudy.image}
          alt="給自己的情書活動封面"
          loading="lazy"
        />
      </div>
      <div class="sdb-case__copy">
        <p class="sdb-kicker">Partner case</p>
        <h2 id="case-title">{page.caseStudy.title}</h2>
        <p>{page.caseStudy.summary}</p>
        <ul>
          {page.caseStudy.facts.map((fact) => <li>{fact}</li>)}
        </ul>
        <a href={page.caseStudy.href} target="_blank" rel="noopener"
          >閱讀合作案例</a
        >
      </div>
    </section>

    <section class="sdb-section" aria-labelledby="package-title">
      <div class="sdb-section__head">
        <p class="sdb-kicker">Collaboration formats</p>
        <h2 id="package-title">三種合作與贊助包裝</h2>
      </div>
      <div class="sdb-package-grid">
        {
          page.packages.map((item) => (
            <article>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="sdb-section" aria-labelledby="authors-title">
      <div class="sdb-section__head">
        <p class="sdb-kicker">Author and work discovery</p>
        <h2 id="authors-title">用標籤入口串接作者群</h2>
        <p>不做單一作者排行榜，改以標籤導流到活動作品、合作案例與長期社群。</p>
      </div>
      <div class="sdb-tag-grid">
        {
          page.tagLinks.map((tag) => (
            <a href={tag.href} target="_blank" rel="noopener">
              <span>{tag.label}</span>
              <strong>{tag.count}</strong>
            </a>
          ))
        }
      </div>
    </section>

    <section id="contact" class="sdb-contact" aria-labelledby="contact-title">
      <div>
        <p class="sdb-kicker">Next partnership</p>
        <h2 id="contact-title">一起設計下一個能被持續書寫的公共議題</h2>
        <p>
          適合文化機構、基金會、出版品牌、教育單位與希望支持公共書寫的企業。正式上線前可把
          mailto fallback 替換為表單服務或 CRM 端點。
        </p>
        <a class="sdb-button sdb-button--primary" href={page.contactHref}
          >洽談合作</a
        >
      </div>
      <form
        class="sdb-form"
        action={page.contactHref}
        method="post"
        enctype="text/plain"
      >
        <label>
          合作單位
          <input name="organization" autocomplete="organization" />
        </label>
        <label>
          聯絡人
          <input name="contact" autocomplete="name" />
        </label>
        <label>
          合作方向
          <select name="direction">
            <option>主題徵文</option>
            <option>作家講座</option>
            <option>品牌共創題目</option>
            <option>其他合作</option>
          </select>
        </label>
        <label>
          預計時程
          <input name="timeline" />
        </label>
        <label class="sdb-form__wide">
          補充說明
          <textarea name="message" rows="4"></textarea>
        </label>
        <button type="submit">送出合作意向</button>
      </form>
    </section>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #fafaf7;
  }

  .sdb-page {
    --sdb-ink: #1c1a17;
    --sdb-muted: #69645c;
    --sdb-line: #d8d1c5;
    --sdb-paper: #fffdf8;
    --sdb-warm: #efe6d6;
    --sdb-green: #24463d;
    --sdb-gold: #b37a28;
    color: var(--sdb-ink);
    background:
      linear-gradient(90deg, rgba(36, 70, 61, 0.06) 1px, transparent 1px),
      linear-gradient(#fafaf7, #f5efe5 60%, #fafaf7);
    background-size:
      88px 88px,
      auto;
    min-height: 100vh;
    font-family: var(--font-sans);
  }

  .sdb-header,
  .sdb-hero,
  .sdb-section,
  .sdb-contact {
    width: min(1120px, calc(100% - 40px));
    margin-inline: auto;
  }

  .sdb-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 28px 0 18px;
    border-bottom: 1px solid var(--sdb-ink);
  }

  .sdb-brand {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    text-decoration: none;
  }

  .sdb-nav {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .sdb-nav a,
  .sdb-inline-links a,
  .sdb-source-row a,
  .sdb-case__copy a {
    color: inherit;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .sdb-hero {
    min-height: min(760px, calc(100vh - 96px));
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.72fr);
    gap: clamp(32px, 6vw, 72px);
    align-items: center;
    padding: clamp(48px, 8vw, 96px) 0;
  }

  .sdb-kicker {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sdb-muted);
  }

  .sdb-hero h1,
  .sdb-section h2,
  .sdb-contact h2 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.08;
    text-wrap: balance;
  }

  .sdb-hero h1 {
    max-width: 11ch;
    margin: 0;
    font-size: clamp(3.25rem, 9vw, 7.5rem);
  }

  .sdb-hero__lead {
    max-width: 660px;
    margin: 28px 0 0;
    font-size: clamp(1.2rem, 2vw, 1.65rem);
    line-height: 1.58;
    color: var(--sdb-muted);
    text-wrap: balance;
  }

  .sdb-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 34px;
  }

  .sdb-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 20px;
    border: 1px solid var(--sdb-ink);
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .sdb-button:hover {
    transform: translateY(-1px);
  }

  .sdb-button--primary {
    background: var(--sdb-ink);
    color: #fffdf8;
  }

  .sdb-button--secondary {
    background: transparent;
  }

  .sdb-hero__panel {
    align-self: stretch;
    min-height: 520px;
    display: grid;
    grid-template-rows: 1fr auto;
    border: 1px solid var(--sdb-line);
    background: var(--sdb-paper);
    overflow: hidden;
  }

  .sdb-hero__panel img {
    width: 100%;
    height: 100%;
    min-height: 360px;
    object-fit: cover;
  }

  .sdb-hero__proof {
    display: grid;
    gap: 6px;
    padding: 22px;
    border-top: 1px solid var(--sdb-line);
  }

  .sdb-hero__proof span,
  .sdb-hero__proof small,
  .sdb-metric small,
  .sdb-account small {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--sdb-muted);
  }

  .sdb-hero__proof strong {
    font-size: 1.05rem;
  }

  .sdb-section {
    padding: clamp(52px, 8vw, 96px) 0;
    border-top: 1px solid var(--sdb-line);
  }

  .sdb-section--tight {
    padding-top: 72px;
  }

  .sdb-section--split {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: start;
  }

  .sdb-section__head {
    max-width: 760px;
    margin-bottom: 28px;
  }

  .sdb-section__head h2,
  .sdb-contact h2,
  .sdb-case__copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4.4vw, 4.75rem);
  }

  .sdb-section__head p:not(.sdb-kicker),
  .sdb-section__after,
  .sdb-case__copy p,
  .sdb-contact p {
    color: var(--sdb-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .sdb-metric-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    border: 1px solid var(--sdb-line);
    background: var(--sdb-paper);
  }

  .sdb-metric {
    min-height: 210px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    padding: 24px;
    border-right: 1px solid var(--sdb-line);
  }

  .sdb-metric:last-child {
    border-right: 0;
  }

  .sdb-metric strong {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 5rem);
    line-height: 0.95;
  }

  .sdb-metric strong span {
    display: block;
    margin-top: 8px;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--sdb-muted);
  }

  .sdb-metric p {
    margin: auto 0 0;
    font-weight: 700;
  }

  .sdb-source-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--sdb-muted);
  }

  .sdb-account,
  .sdb-values,
  .sdb-package-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .sdb-account article,
  .sdb-values article,
  .sdb-package-grid article,
  .sdb-workflow article,
  .sdb-note {
    background: rgba(255, 253, 248, 0.82);
    border: 1px solid var(--sdb-line);
    padding: 22px;
  }

  .sdb-account strong {
    display: block;
    font-family: var(--font-display);
    font-size: 3rem;
    line-height: 1;
  }

  .sdb-account span {
    display: block;
    margin: 10px 0 12px;
    font-weight: 700;
  }

  .sdb-note {
    display: grid;
    gap: 12px;
  }

  .sdb-note p {
    margin: 0;
    color: var(--sdb-muted);
  }

  .sdb-workflow {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .sdb-workflow span {
    font-family: var(--font-display);
    font-size: 3.25rem;
    color: var(--sdb-gold);
  }

  .sdb-workflow h3,
  .sdb-theme h3,
  .sdb-values h3,
  .sdb-package-grid h3 {
    margin: 0 0 12px;
    font-size: 1.3rem;
    line-height: 1.28;
  }

  .sdb-workflow p,
  .sdb-theme p,
  .sdb-values p,
  .sdb-package-grid p {
    margin: 0;
    color: var(--sdb-muted);
    line-height: 1.72;
  }

  .sdb-section__after {
    max-width: 720px;
    margin: 22px 0 0;
  }

  .sdb-theme-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .sdb-theme {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 22px;
    min-height: 260px;
    padding: 18px;
    background: var(--sdb-paper);
    border: 1px solid var(--sdb-line);
  }

  .sdb-theme__images {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 10px;
  }

  .sdb-theme__images a {
    display: block;
    overflow: hidden;
    background: var(--sdb-warm);
  }

  .sdb-theme__images img {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .sdb-theme__images a:hover img {
    transform: scale(1.03);
  }

  .sdb-inline-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .sdb-keywords {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .sdb-keywords span,
  .sdb-tag-grid a {
    border: 1px solid var(--sdb-line);
    background: var(--sdb-paper);
  }

  .sdb-keywords span {
    padding: 10px 14px;
    border-radius: 999px;
  }

  .sdb-case {
    display: grid;
    grid-template-columns: minmax(300px, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }

  .sdb-case__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border: 1px solid var(--sdb-line);
    background: var(--sdb-paper);
  }

  .sdb-case__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sdb-case__copy ul {
    margin: 22px 0;
    padding-left: 1.2em;
    color: var(--sdb-muted);
  }

  .sdb-case__copy li + li {
    margin-top: 8px;
  }

  .sdb-tag-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .sdb-tag-grid a {
    min-height: 132px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 18px;
    text-decoration: none;
  }

  .sdb-tag-grid span {
    font-weight: 700;
  }

  .sdb-tag-grid strong {
    font-family: var(--font-mono);
    color: var(--sdb-muted);
  }

  .sdb-contact {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: start;
    padding: clamp(52px, 8vw, 96px) 0;
    border-top: 1px solid var(--sdb-ink);
  }

  .sdb-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    padding: 22px;
    background: var(--sdb-paper);
    border: 1px solid var(--sdb-line);
  }

  .sdb-form label {
    display: grid;
    gap: 8px;
    font-weight: 700;
  }

  .sdb-form input,
  .sdb-form select,
  .sdb-form textarea {
    width: 100%;
    border: 1px solid var(--sdb-line);
    background: #fff;
    color: var(--sdb-ink);
    padding: 12px;
    font: inherit;
    border-radius: 0;
  }

  .sdb-form__wide,
  .sdb-form button {
    grid-column: 1 / -1;
  }

  .sdb-form button {
    min-height: 46px;
