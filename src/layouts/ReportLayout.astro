---
import BaseHead from "../components/BaseHead.astro";
import Mesh from "../components/Mesh.astro";
import Guides from "../components/Guides.astro";
import Masthead from "../components/Masthead.astro";
import Iris from "../components/Iris.astro";
import Footer from "../components/Footer.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import TableOfContents from "../components/TableOfContents.astro";
import AiMetaBadge from "../components/AiMetaBadge.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import CitationTooltip from "../components/CitationTooltip.astro";
import PostPage from "../components/islands/PostPage.tsx";
import { formatDate } from "../utils/date";
import { readingTime } from "../utils/reading-time";
import { getPublishedReports } from "../utils/reports";
import { reportToPost } from "../lib/reports-to-posts";
import "../styles/global.css";

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  body: string;
  aiModel?: string;
  aiPrompt?: string;
  aiGeneratedDate?: Date;
  humanReviewed?: boolean;
}

const {
  id,
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  headings,
  body,
  aiModel,
  aiPrompt,
  aiGeneratedDate,
  humanReviewed,
} = Astro.props;

const kicker = tags[0] ?? "Essay";
const readTime = readingTime(body);
const ogImage = `og/${id}.png`;

// Related pool — everything except this report
const allReports = await getPublishedReports();
const otherPosts = allReports
  .filter((r) => r.id !== id)
  .map(reportToPost);
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} />
  </head>
  <body>
    <Mesh />
    <Guides />
    <ReadingProgress />
    <Masthead />

    <article class="article">
      <a href="/" class="article__back">← All essays</a>

      <p class="article__kicker">{kicker}</p>
      <h1 class="article__title">{title}</h1>
      <p class="article__lede">“{description}”</p>

      <div class="article__meta">
        <span>
          <strong>{aiModel ?? "AI Research Pipeline"}</strong>
        </span>
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {updatedDate && <span>· 更新於 {formatDate(updatedDate)}</span>}
        <span>{readTime}</span>
        <span style="margin-left:auto">#{id.split("/").pop()}</span>
      </div>

      {tags.length > 0 && (
        <div class="article__tags">
          {tags.map((tag) => (
            <a class="article__tag" href={`/tags/${tag}/`}>#{tag}</a>
          ))}
        </div>
      )}

      <AiMetaBadge
        aiModel={aiModel}
        aiPrompt={aiPrompt}
        aiGeneratedDate={aiGeneratedDate}
        humanReviewed={humanReviewed}
      />

      <div class="article__body report-prose">
        <slot />
      </div>

      <aside class="article__sidebar">
        <TableOfContents headings={headings} />
      </aside>
    </article>

    <PostPage client:only="react" currentId={id} others={otherPosts} />

    <Footer />
    <Iris />
    <ScrollReveal />
    <CitationTooltip />

    <style>
      .article__tags {
        display: flex;
        gap: var(--space-2);
        flex-wrap: wrap;
        margin: 0 0 var(--space-6);
      }
      .article__tag {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--color-ink-muted);
        text-decoration: none;
        padding: 2px 10px;
        border-radius: var(--radius-pill);
        border: 1px solid var(--color-rule);
        transition: all var(--dur-fast) var(--ease-standard);
      }
      .article__tag:hover {
        color: var(--color-ink);
        border-color: var(--color-ink);
      }
      .article__sidebar {
        display: none;
      }
      @media (min-width: 1100px) {
        .article {
          display: grid;
          grid-template-columns: minmax(0, 1fr) 220px;
          gap: var(--space-7);
          max-width: 960px;
          align-items: start;
        }
        .article > *:not(.article__sidebar) {
          grid-column: 1;
        }
        .article__sidebar {
          display: block;
          grid-column: 2;
          grid-row: 1 / span 8;
          position: sticky;
          top: var(--space-6);
        }
      }
    </style>
  </body>
</html>
