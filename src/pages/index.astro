---
import BaseLayout from "../layouts/BaseLayout.astro";
import MattersWordmark from "../components/MattersWordmark.astro";
import { sevenDayBookLanding as page } from "../data/seven-day-book";

const nav = [
  { href: "#pulse", label: "此刻在寫" },
  { href: "#events", label: "歷屆題目" },
  { href: "#voices", label: "作品節錄" },
  { href: "#passport", label: "大滿貫" },
  { href: "#partners", label: "合作" },
];

// avatars 分三排做散佈，利用 nth-child 錯位
const avatars = page.avatarWall;
---

<BaseLayout title="七日書" description={page.description}>
  <!-- ============================================================= -->
  <!-- Top bar — Matters wordmark + nav                              -->
  <!-- ============================================================= -->
  <div class="topbar">
    <a class="topbar__brand" href="https://matters.town" target="_blank" rel="noopener">
      <MattersWordmark size={18} />
      <span class="topbar__dot" aria-hidden="true">·</span>
      <span class="topbar__product">七日書</span>
    </a>
    <nav class="topbar__nav" aria-label="頁面導覽">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="topbar__cta">
      <a href={page.hero.primaryCta.href} class="chip">看作品</a>
      <a href="#contact" class="chip chip--filled">洽談合作</a>
    </div>
  </div>

  <main class="sdb">
    <!-- ========================================================= -->
    <!-- HERO — full-bleed backdrop collage + emotional headline   -->
    <!-- ========================================================= -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__backdrop" aria-hidden="true">
        <img class="hero__cover hero__cover--main" src={page.hero.heroCover} alt="" loading="eager" />
        <div class="hero__tile-grid">
          {page.hero.backdropCovers.map((src, i) => (
            <img class={`hero__tile hero__tile--${i}`} src={src} alt="" loading="lazy" />
          ))}
        </div>
        <div class="hero__vignette"></div>
      </div>

      <div class="hero__inner">
        <p class="hero__eyebrow">
          <span class="pulse-dot" aria-hidden="true"></span>
          {page.hero.eyebrow}
        </p>
        <h1 class="hero__title" id="hero-title">
          {page.hero.headline}
        </h1>
        <p class="hero__lead">{page.hero.subheadline}</p>
        <div class="hero__cta">
          <a class="btn btn--primary" href={page.hero.primaryCta.href} target="_blank" rel="noopener">
            {page.hero.primaryCta.label}
            <span class="btn__arrow" aria-hidden="true">→</span>
          </a>
          <a class="btn btn--ghost" href={page.hero.secondaryCta.href} target="_blank" rel="noopener">
            {page.hero.secondaryCta.label}
          </a>
        </div>

        <!-- floating avatar strip at hero bottom -->
        <div class="hero__avatars" aria-label="部分參與者頭像">
          {avatars.slice(0, 12).map((a, i) => (
            <a
              class={`hero__av hero__av--${i}`}
              href={`https://matters.town/@${a.handle}`}
              target="_blank"
              rel="noopener"
              title={a.name}
              style={`--delay: ${i * 120}ms`}
            >
              <img src={a.src} alt={a.name} loading="lazy" />
            </a>
          ))}
          <a class="hero__av hero__av--more" href="#pulse" aria-label="看更多參與者">
            <span>+280</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ========================================================= -->
    <!-- PULSE — now writing, stats + 30 avatars                   -->
    <!-- ========================================================= -->
    <section id="pulse" class="section pulse" aria-labelledby="pulse-title" data-reveal>
      <header class="section__head">
        <p class="kicker">{page.pulse.kicker}</p>
        <h2 id="pulse-title">{page.pulse.headline}</h2>
        <p class="section__body">{page.pulse.body}</p>
      </header>

      <div class="stat-row">
        {page.pulse.stats.map((s) => (
          <div class="stat">
            <strong>{s.value}</strong>
            <span>{s.label}</span>
          </div>
        ))}
      </div>

      <ul class="avatar-wall" aria-label="近期參與文友頭像">
        {avatars.map((a, i) => (
          <li style={`--i: ${i}`}>
            <a href={`https://matters.town/@${a.handle}`} target="_blank" rel="noopener" title={a.name}>
              <img src={a.src} alt={a.name} loading="lazy" />
            </a>
          </li>
        ))}
      </ul>

      <p class="source-line">
        <a href={page.pulse.source.href} target="_blank" rel="noopener">{page.pulse.source.label} →</a>
      </p>
    </section>

    <!-- ========================================================= -->
    <!-- CADENCE — seven-day shape as day chips                    -->
    <!-- ========================================================= -->
    <section class="section cadence" aria-labelledby="cadence-title" data-reveal>
      <header class="section__head">
        <p class="kicker">{page.cadence.kicker}</p>
        <h2 id="cadence-title">{page.cadence.headline}</h2>
        <p class="section__body">{page.cadence.body}</p>
      </header>
      <ol class="days">
        {page.cadence.days.map((d) => (
          <li class="day" style={`--i: ${d.n}`}>
            <span class="day__num">{d.n}</span>
            <span class="day__kw">{d.kw}</span>
            <span class="day__prompt">{d.prompt}</span>
          </li>
        ))}
      </ol>
    </section>

    <!-- ========================================================= -->
    <!-- EVENTS — 8 期 marquee timeline                            -->
    <!-- ========================================================= -->
    <section id="events" class="section events" aria-labelledby="events-title" data-reveal>
      <header class="section__head">
        <p class="kicker">Seasons</p>
        <h2 id="events-title">八期題目，一座書寫小鎮。</h2>
        <p class="section__body">
          從 2025 秋到 2026 夏——每一期主題像是一條街，作者是路過的居民。滑看近八期，點進去是那一季的文字聚會。
        </p>
      </header>

      <div class="marquee" data-marquee>
        <div class="marquee__track">
          {[...page.events, ...page.events].map((e, i) => (
            <a class={`evcard evcard--${e.phase === "進行中" ? "live" : e.phase === "即將開始" ? "soon" : "done"}`}
               href={e.href} target="_blank" rel="noopener" aria-hidden={i >= page.events.length}>
              <div class="evcard__media">
                <img src={e.cover} alt={`${e.name} 主視覺`} loading="lazy" />
                <span class={`evcard__phase evcard__phase--${e.phase === "進行中" ? "live" : e.phase === "即將開始" ? "soon" : "done"}`}>
                  {e.phase}
                </span>
              </div>
              <div class="evcard__body">
                <span class="evcard__season">{e.season}</span>
                <h3 class="evcard__name">七日書｜{e.name}</h3>
                <p class="evcard__desc">{e.description}</p>
                <div class="evcard__meta">
                  <span>{e.writingWindow}</span>
                  {e.participants && (
                    <span class="evcard__chip">{e.participants} 位完成</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ========================================================= -->
    <!-- VOICES — 6 real essay excerpts                            -->
    <!-- ========================================================= -->
    <section id="voices" class="section voices" aria-labelledby="voices-title" data-reveal>
      <header class="section__head">
        <p class="kicker">Voices</p>
        <h2 id="voices-title">他們在七天裡寫了這些。</h2>
        <p class="section__body">
          隨機六段近三期的文字。點進去讀完整篇——每段背後都是一位具體的人、一段具體的週三下午。
        </p>
      </header>
      <div class="voice-grid">
        {page.voices.map((v, i) => (
          <a class="voice" href={v.href} target="_blank" rel="noopener" style={`--i: ${i}`}>
            <div class="voice__top">
              <img class="voice__avatar" src={v.avatar} alt={v.author} loading="lazy" />
              <div class="voice__meta">
                <span class="voice__author">{v.author}</span>
                <span class="voice__season">{v.season}</span>
              </div>
              <span class="voice__day">{v.dayLabel}</span>
            </div>
            <h3 class="voice__title">{v.title}</h3>
            <p class="voice__excerpt">「{v.excerpt}」</p>
            <span class="voice__more">讀完整篇 →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ========================================================= -->
    <!-- PASSPORT — 大滿貫憑證                                      -->
    <!-- ========================================================= -->
    <section id="passport" class="section passport" aria-labelledby="passport-title" data-reveal>
      <div class="passport__copy">
        <p class="kicker">{page.passport.kicker}</p>
        <h2 id="passport-title">{page.passport.headline}</h2>
        <p class="section__body">{page.passport.body}</p>
        <a class="btn btn--ghost" href={page.passport.link.href} target="_blank" rel="noopener">
          {page.passport.link.label} →
        </a>
      </div>
      <div class="passport__art">
        <img src={page.passport.image} alt={page.passport.imageAlt} loading="lazy" />
      </div>
    </section>

    <!-- ========================================================= -->
    <!-- PARTNERS — B2B 次層                                        -->
    <!-- ========================================================= -->
    <section id="partners" class="section partners" aria-labelledby="partners-title" data-reveal>
      <header class="section__head">
        <p class="kicker">{page.partners.kicker}</p>
        <h2 id="partners-title">{page.partners.headline}</h2>
        <p class="section__body">{page.partners.body}</p>
      </header>

      <div class="case">
        <div class="case__media">
          <img src={page.partners.caseStudy.image} alt={page.partners.caseStudy.title} loading="lazy" />
        </div>
        <div class="case__copy">
          <span class="kicker">Partner case</span>
          <h3>{page.partners.caseStudy.title}</h3>
          <p>{page.partners.caseStudy.summary}</p>
          <ul>
            {page.partners.caseStudy.facts.map((f) => <li>{f}</li>)}
          </ul>
        </div>
      </div>

      <div class="packages">
        {page.partners.packages.map((p) => (
          <article class="pkg">
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ========================================================= -->
    <!-- FAQ                                                        -->
    <!-- ========================================================= -->
    <section class="section faq" aria-labelledby="faq-title" data-reveal>
      <header class="section__head">
        <p class="kicker">FAQ</p>
        <h2 id="faq-title">關於七日書</h2>
      </header>
      <div class="faq__list">
        {page.faq.map((f, i) => (
          <details class="faq__item" open={i === 0}>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ========================================================= -->
    <!-- CLOSING + CONTACT                                          -->
    <!-- ========================================================= -->
    <section id="contact" class="section closing" aria-labelledby="closing-title" data-reveal>
      <h2 id="closing-title">{page.closing.headline}</h2>
      <p class="closing__body">{page.closing.body}</p>
      <div class="hero__cta closing__cta">
        <a class="btn btn--primary" href={page.closing.primaryCta.href} target="_blank" rel="noopener">
          {page.closing.primaryCta.label}
        </a>
        <a class="btn btn--ghost" href={page.contactHref}>
          {page.closing.secondaryCta.label}
        </a>
      </div>
    </section>

    <footer class="footer">
      <div class="footer__brand">
        <MattersWordmark size={14} />
        <span>· 七日書</span>
      </div>
      <div class="footer__links">
        <a href="https://matters.town/@freewrite" target="_blank" rel="noopener">@freewrite</a>
        <a href="https://matters.town/tags/167821-%E4%B8%83%E6%97%A5%E6%9B%B8" target="_blank" rel="noopener">#七日書</a>
        <a href="https://matters.town" target="_blank" rel="noopener">matters.town</a>
      </div>
      <span class="footer__c">© {new Date().getFullYear()} Matters Lab</span>
    </footer>
  </main>
</BaseLayout>

<script>
  // Scroll reveal — add .is-visible when section enters viewport
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("is-visible");
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -80px 0px" },
  );
  document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));

  // Pause marquee on hover
  document.querySelectorAll("[data-marquee]").forEach((m) => {
    m.addEventListener("mouseenter", () => m.classList.add("is-paused"));
    m.addEventListener("mouseleave", () => m.classList.remove("is-paused"));
  });
</script>

<style>
  :global(html) {
    scroll-padding-top: 72px;
  }
  :global(body) {
    background: var(--freewrite-bg);
    background-image:
      radial-gradient(at 20% 0%, rgba(25, 153, 208, 0.08) 0, transparent 50%),
      radial-gradient(at 90% 80%, rgba(4, 88, 152, 0.06) 0, transparent 60%);
  }

  /* ─── Top bar ─────────────────────────────────────────────── */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
    padding: 14px clamp(20px, 4vw, 40px);
    background: rgba(240, 249, 254, 0.85);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid rgba(131, 186, 209, 0.4);
  }
  .topbar__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    text-decoration: none;
    font-family: var(--font-reading);
    font-weight: 600;
    transition: color 200ms;
  }
  .topbar__brand:hover {
    color: var(--freewrite-text-dark);
  }
  .topbar__dot {
    color: var(--freewrite-label);
  }
  .topbar__product {
    font-size: 15px;
    letter-spacing: 0.04em;
  }
  .topbar__nav {
    display: flex;
    justify-content: center;
    gap: 22px;
    font-size: 14px;
  }
  .topbar__nav a {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 180ms;
  }
  .topbar__nav a:hover {
    color: var(--freewrite-text-dark);
  }
  .topbar__cta {
    display: flex;
    gap: 8px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid var(--freewrite-label);
    background: transparent;
    color: var(--freewrite-text-dark);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: background 180ms, transform 180ms;
  }
  .chip:hover {
    background: var(--warm);
    transform: translateY(-1px);
  }
  .chip--filled {
    background: var(--freewrite-text-dark);
    border-color: var(--freewrite-text-dark);
    color: #fff;
  }
  .chip--filled:hover {
    background: var(--freewrite-text);
    border-color: var(--freewrite-text);
  }
  @media (max-width: 820px) {
    .topbar {
      grid-template-columns: auto auto;
      gap: 12px;
    }
    .topbar__nav {
      display: none;
    }
  }

  /* ─── Main container ──────────────────────────────────────── */
  .sdb {
    font-family: var(--font-ui);
    color: var(--ink);
  }

  /* ─── HERO ────────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: min(880px, 100vh);
    padding: clamp(80px, 12vw, 140px) clamp(20px, 4vw, 48px) 64px;
    color: #fff;
  }
  .hero__backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__cover--main {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.55) saturate(1.15);
    transform: scale(1.05);
    animation: slow-drift 22s ease-in-out infinite alternate;
  }
  @keyframes slow-drift {
    from { transform: scale(1.05) translate(0, 0); }
    to { transform: scale(1.1) translate(-1%, -1%); }
  }
  .hero__tile-grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 0;
    opacity: 0.35;
    mix-blend-mode: screen;
    pointer-events: none;
  }
  .hero__tile {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.25) contrast(1.05);
  }
  .hero__tile--0 { grid-column: 1 / 3; grid-row: 1 / 2; }
  .hero__tile--1 { grid-column: 3 / 5; grid-row: 2 / 3; }
  .hero__tile--2 { grid-column: 1 / 2; grid-row: 3 / 4; }
  .hero__tile--3 { grid-column: 3 / 4; grid-row: 3 / 4; }
  .hero__vignette {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(4, 88, 152, 0.35) 0%, rgba(2, 30, 55, 0.55) 60%, rgba(2, 30, 55, 0.8) 100%);
  }
  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 1120px;
    margin: 0 auto;
  }
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 20px;
    padding: 6px 14px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.05em;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(6px);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #c3f432; /* Matters new-palette lime — 唯一用在 pulse 指示 */
    box-shadow: 0 0 0 0 rgba(195, 244, 50, 0.7);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(195, 244, 50, 0.7); }
    70% { box-shadow: 0 0 0 12px rgba(195, 244, 50, 0); }
    100% { box-shadow: 0 0 0 0 rgba(195, 244, 50, 0); }
  }
  .hero__title {
    margin: 0;
    font-family: var(--font-reading);
    font-weight: 700;
    font-size: clamp(2.5rem, 6.5vw, 5.5rem);
    line-height: 1.15;
    letter-spacing: 0.01em;
    text-wrap: balance;
    max-width: 16ch;
  }
  .hero__lead {
    max-width: 640px;
    margin: 28px 0 0;
    font-size: clamp(1.05rem, 1.5vw, 1.35rem);
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.92);
    text-wrap: pretty;
  }
  .hero__cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 36px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 50px;
    padding: 0 26px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    transition: transform 180ms, background 200ms, color 200ms, border-color 200ms;
    border: 1px solid transparent;
  }
  .btn:hover {
    transform: translateY(-2px);
  }
  .btn__arrow {
    transition: transform 200ms;
  }
  .btn:hover .btn__arrow {
    transform: translateX(4px);
  }
  .btn--primary {
    background: #fff;
    color: var(--freewrite-text-dark);
    border-color: #fff;
  }
  .btn--primary:hover {
    background: var(--freewrite-text-dark);
    color: #fff;
    border-color: var(--freewrite-text-dark);
  }
  .btn--ghost {
    background: transparent;
    color: currentColor;
    border-color: rgba(255, 255, 255, 0.6);
  }
  .btn--ghost:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: #fff;
  }
  /* In light sections, btn--ghost takes ink theme */
  .section .btn--primary {
    background: var(--freewrite-text-dark);
    color: #fff;
    border-color: var(--freewrite-text-dark);
  }
  .section .btn--primary:hover {
    background: var(--freewrite-text);
    border-color: var(--freewrite-text);
  }
  .section .btn--ghost {
    color: var(--freewrite-text-dark);
    border-color: var(--freewrite-label);
  }
  .section .btn--ghost:hover {
    background: var(--warm);
    border-color: var(--freewrite-text-dark);
  }

  .hero__avatars {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    margin-top: 48px;
    max-width: 620px;
  }
  .hero__av {
    display: block;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.92);
    background: #fff;
    box-shadow: 0 2px 8px rgba(2, 30, 55, 0.3);
    transition: transform 220ms cubic-bezier(0.34, 1.56, 0.64, 1);
    animation: av-fade-in 600ms ease-out both;
    animation-delay: var(--delay, 0ms);
  }
  .hero__av:hover {
    transform: translateY(-6px) scale(1.2);
    z-index: 3;
  }
  .hero__av img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__av--more {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    backdrop-filter: blur(6px);
  }
  @keyframes av-fade-in {
    from { opacity: 0; transform: translateY(8px) scale(0.85); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ─── Section base ────────────────────────────────────────── */
  .section {
    position: relative;
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(72px, 10vw, 120px) clamp(20px, 4vw, 48px);
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 700ms ease-out, transform 700ms ease-out;
  }
  .section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .section {
