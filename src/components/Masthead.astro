---
import { SITE_TITLE, MAIN_SITE_URL } from "../site.config";

export interface Props {
  /** Override the brand line; defaults to SITE_TITLE. */
  brand?: string;
  /** Provide navigation links. */
  nav?: { href: string; label: string }[];
}

const {
  brand = SITE_TITLE,
  nav = [
    { href: "/", label: "Essays" },
    { href: "/about/", label: "About" },
    { href: "/design-system/", label: "DS" },
  ],
} = Astro.props as Props;
---

<header class="masthead">
  <a href="/" class="masthead__brand">{brand}<span>.</span></a>
  <div class="masthead__right">
    <nav class="masthead__nav">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a
      class="masthead__cta"
      href={MAIN_SITE_URL}
      target="_blank"
      rel="noopener"
    >
      ← 回到豆泥部落格
    </a>
  </div>
</header>
<div class="masthead__rule"></div>

<style>
  .masthead__right {
    display: flex;
    align-items: baseline;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .masthead__cta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink);
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-pill);
    transition: all var(--dur-fast) var(--ease-standard);
    white-space: nowrap;
  }
  .masthead__cta:hover {
    background: var(--color-ink);
    color: var(--color-canvas);
  }
  @media (max-width: 768px) {
    .masthead__right { gap: var(--space-3); }
    .masthead__cta { padding: 4px 10px; }
  }
</style>
