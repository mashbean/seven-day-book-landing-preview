---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/paths";
---

<BaseLayout title="404" noindex>
  <main class="nf">
    <p class="nf__code">404</p>
    <p class="nf__msg">找不到這個頁面</p>
    <a class="nf__link" href={withBase("/")}>返回首頁</a>
  </main>
</BaseLayout>

<style>
  .nf {
    min-height: 60vh;
    display: grid;
    place-content: center;
    text-align: center;
    gap: 16px;
    padding: 96px 24px;
  }
  .nf__code {
    font-family: var(--font-reading);
    font-size: 4rem;
    font-weight: 700;
    color: var(--freewrite-text-dark);
    margin: 0;
  }
  .nf__msg {
    color: var(--ink-muted);
    margin: 0 0 16px;
  }
  .nf__link {
    display: inline-block;
    padding: 10px 22px;
    border: 1px solid var(--freewrite-text-dark);
    border-radius: 999px;
    color: var(--freewrite-text-dark);
    text-decoration: none;
    font-weight: 700;
  }
  .nf__link:hover {
    background: var(--freewrite-text-dark);
    color: #fff;
  }
</style>
