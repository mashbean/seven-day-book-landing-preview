---
import { formatDate } from "../utils/date";

interface Props {
  aiModel?: string;
  aiPrompt?: string;
  aiGeneratedDate?: Date;
  humanReviewed?: boolean;
}

const { aiModel, aiPrompt, aiGeneratedDate, humanReviewed } = Astro.props;
const hasAnyMeta = aiModel || aiPrompt || aiGeneratedDate;
---

{hasAnyMeta && (
  <details class="mt-4 mb-8 rounded-xl border border-[var(--color-border)]
                  bg-[var(--color-bg-glass)] backdrop-blur-md text-sm">
    <summary class="px-4 py-2.5 cursor-pointer text-[var(--color-secondary)]
                    hover:text-[var(--color-accent)] transition-colors
                    flex items-center gap-2">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 2a4 4 0 014 4v1a2 2 0 012 2v1a4 4 0 01-4 4h-4a4 4 0 01-4-4V9a2 2 0 012-2V6a4 4 0 014-4z"/>
        <path d="M9 18v3m6-3v3M8 22h8"/>
      </svg>
      AI 生成資訊
      {humanReviewed && (
        <span class="ml-auto text-xs px-2 py-0.5 rounded-full border border-green-500/30 text-green-400">
          已人工審閱
        </span>
      )}
    </summary>
    <div class="px-4 pb-3 pt-1 space-y-1.5 text-[var(--color-text-muted)]">
      {aiModel && (
        <p><span class="font-medium text-[var(--color-text)]">模型：</span>{aiModel}</p>
      )}
      {aiGeneratedDate && (
        <p><span class="font-medium text-[var(--color-text)]">生成日期：</span>{formatDate(aiGeneratedDate)}</p>
      )}
      {aiPrompt && (
        <p><span class="font-medium text-[var(--color-text)]">提問：</span>{aiPrompt}</p>
      )}
    </div>
  </details>
)}
