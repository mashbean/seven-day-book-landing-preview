---
import { formatDate } from "../utils/date";
import { readingTime } from "../utils/reading-time";
import { withBase } from "../utils/paths";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  body: string;
  aiModel?: string;
}

const { title, description, pubDate, tags, slug, body, aiModel } = Astro.props;
---

<a
  href={withBase(`/reports/${slug}/`)}
  class="report-card group block relative rounded-2xl p-6
         border border-[var(--color-border-glass)] bg-[var(--color-bg-glass)]
         backdrop-blur-md overflow-hidden"
  data-tags={tags.join(",")}
>
  <!-- Meta line -->
  <div class="flex items-center gap-3 text-xs text-[var(--color-text-muted)] mb-3">
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    <span class="opacity-40">|</span>
    <span>{readingTime(body)}</span>
    {aiModel && (
      <>
        <span class="opacity-40">|</span>
        <span class="flex items-center gap-1 text-[var(--color-secondary)]">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2a4 4 0 014 4v1a2 2 0 012 2v1a4 4 0 01-4 4h-4a4 4 0 01-4-4V9a2 2 0 012-2V6a4 4 0 014-4z"/>
            <path d="M9 18v3m6-3v3M8 22h8"/>
          </svg>
          {aiModel}
        </span>
      </>
    )}
  </div>

  <!-- Title -->
  <h2 class="text-xl font-bold font-serif mb-2 text-[var(--color-text)]
             group-hover:text-[var(--color-accent)] transition-colors">
    {title}
  </h2>

  <!-- Description -->
  <p class="text-sm text-[var(--color-text-muted)] line-clamp-2 mb-4">
    {description}
  </p>

  <!-- Tags -->
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-xs px-2.5 py-0.5 rounded-full
                     border border-[var(--color-border)]
                     text-[var(--color-text-muted)]">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
